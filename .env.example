# --- Admin /admin (site personnel : les secrets VITE_ sont visibles dans le JS livré) ---

# Option A : mot de passe en clair
VITE_ADMIN_PASSWORD=

# Option B (recommandé) : SHA-256 hex du mot de passe, comparé côté navigateur
# Générer : node -e "const c=require('crypto');console.log(c.createHash('sha256').update('TON_MOT').digest('hex'))"
VITE_ADMIN_PASSWORD_SHA256=

# --- SEO (injecté dans index.html au build) ---
# Dans src/data/site.json → seo.siteUrl : URL publique du site (sans slash final),
# pour canonical, og:url et og:image en URL absolue (recommandé pour le partage social).
# seo.twitterSite : handle Twitter avec @ (optionnel).
